[Unit]
Description=SSRF Console Dashboard Frontend
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/kali/SSRF_CONSOLE
EnvironmentFile=/etc/ssrf/ssrf.env
ExecStart=/home/kali/SSRF_CONSOLE/venv/bin/python dashboard_web.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
